---
interface Props {
	spacingTop?: 'none' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
	spacingBottom?: 'none' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';

	width?: 'full' | 'wide' | 'narrow';

	background?: 'default' | 'surface' | 'accent' | 'dark';

	borderTop?: boolean;
	borderBottom?: boolean;

	class?: string;
}

const {
	spacingTop = 'none',
	spacingBottom = 'none',
	width = 'wide',
	background = 'default',
	borderTop = false,
	borderBottom = false,
	class: className,
}: Props = Astro.props;
---

<section
	class:list={[
		'section',
		`section--pt-${spacingTop}`,
		`section--pb-${spacingBottom}`,
		`section--width-${width}`,
		`section--bg-${background}`,
		{
			'section--border-top': borderTop,
			'section--border-bottom': borderBottom,
		},
		className,
	]}
>
	<div class="section__inner">
		<slot />
	</div>
</section>

<style>
	.section {
		width: 100%;
	}

	.section__inner {
		width: 100%;
		margin-inline: auto;
	}

	.section--width-full .section__inner {
		width: 100%;
		max-width: none;
	}

	.section--width-wide .section__inner {
		width: min(
			calc(100% - (var(--page-gutter) * 2)),
			var(--content-width)
		);
	}

	.section--width-narrow .section__inner {
		width: min(
			calc(100% - (var(--page-gutter) * 2)),
			var(--content-width-narrow)
		);
	}

	.section--bg-default {
		background: var(--color-background);
	}

	.section--bg-surface {
		background: var(--color-surface);
	}

	.section--bg-accent {
		background: var(--color-accent);
	}

	.section--bg-dark {
		background: var(--color-dark);
	}

	.section--border-top {
		border-top: 1px solid var(--color-border);
	}

	.section--border-bottom {
		border-bottom: 1px solid var(--color-border);
	}

	.section--pt-none {
		padding-top: 0;
	}

	.section--pt-sm {
		padding-top: var(--space-sm);
	}

	.section--pt-md {
		padding-top: var(--space-md);
	}

	.section--pt-lg {
		padding-top: var(--space-lg);
	}

	.section--pt-xl {
		padding-top: var(--space-xl);
	}

	.section--pt-2xl {
		padding-top: var(--space-2xl);
	}

	.section--pb-none {
		padding-bottom: 0;
	}

	.section--pb-sm {
		padding-bottom: var(--space-sm);
	}

	.section--pb-md {
		padding-bottom: var(--space-md);
	}

	.section--pb-lg {
		padding-bottom: var(--space-lg);
	}

	.section--pb-xl {
		padding-bottom: var(--space-xl);
	}

	.section--pb-2xl {
		padding-bottom: var(--space-2xl);
	}
</style>