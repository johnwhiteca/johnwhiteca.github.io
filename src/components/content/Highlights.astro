---
import { Icon } from "astro-icon/components";

const highlights = [
	{
		title: "highlight 1",
		description: "some placeholder text here",
		icon: "lucide:heart",
	},
	{
		title: "highlight 2",
		description: "some placeholder text here",
		icon: "lucide:users",
	},
	{
		title: "highlight 3",
		description: "some placeholder text here",
		icon: "lucide:star",
	},
	{
		title: "highlight 4",
		description: "some placeholder text here",
		icon: "lucide:map-pin",
	},
];
---

<div class="highlights">
	{
		highlights.map((item) => (
			<article class="highlights__item">
				<div class="highlights__icon" aria-hidden="true">
					<Icon name={item.icon} />
				</div>

				<div class="highlights__content">
					<h3 class="highlights__title">
						{item.title}
					</h3>

					<p class="highlights__description">
						{item.description}
					</p>
				</div>
			</article>
		))
	}
</div>

<style>
	.highlights {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-lg);
        text-align: center;
	}

    .highlights {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--space-lg);
        padding-block: var(--space-lg);
    }

	.highlights__icon {
		flex: 0 0 auto;
	}

	.highlights__icon :global(svg) {
		display: block;
		width: 1.25rem;
		height: 1.25rem;
	}

	.highlights__title {
		margin: 0;
		font-size: var(--text-base);
	}

	.highlights__description {
		margin: var(--space-xs) 0 0;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	@media (max-width: 800px) {
		.highlights {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 500px) {
		.highlights {
			grid-template-columns: 1fr;
		}
	}
</style>